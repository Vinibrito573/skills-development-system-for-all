<!--HTML page for the System-->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>

  <!-- Styling for the page -->
  <style>
    body { font-family: Arial, sans-serif; max-width: 800px; margin: 30px auto; padding: 0 20px; background: #f5f5f5; }
    h1 { text-align: center; color: #2c3e50; }
    p.subtitle { text-align: center; color: #888; font-size: 14px; }

    /* Creating a card so  each service will be inside of it*/
    .card { background: white; padding: 20px; margin-bottom: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    h2 { color: #2980b9; margin-top: 0; }

    /*Form styling*/
    label { display: block; margin-top: 10px; font-weight: bold; font-size: 14px; }
    input, select { width: 100%; padding: 8px; margin-top: 4px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
    button { margin-top: 12px; padding: 10px 20px; background: #2980b9; color: white; border: none; border-radius: 4px; cursor: pointer; }
    button:hover { background: #1f6391; }

    /* Success in the task, so will be show in green */
    .success { margin-top: 12px; padding: 10px; background: #eafaf1; border-left: 4px solid #27ae60; border-radius: 4px; }

    /* If an error, so will be show in red */
    .error { margin-top: 12px; padding: 10px; background: #fdf2f2; border-left: 4px solid #e74c3c; border-radius: 4px; color: #c0392b; }

  </style>
</head>
<body>

  <!-- Page Title -->
  <h1>🎓 Skills Development System for all </h1>
  <p class="subtitle">Decent Work and Economic Growth</p>

  <!-- First Service: User Training Service -->
  <!-- Using the Unary RPC to assign a training to the user -->

  <div class="card">
    <h2>📚 Assign Training</h2>

    <!-- When the form is submitted, then it sends data to /assign-training in app.js -->
    <form action="/assign-training" method="POST">

      <label>User ID</label>
      <input type="number" name="userId" placeholder="e.g. 1" required>

      <label>Date of Birth</label>
      <input type="text" name="dateOfBirth" placeholder="e.g. 1975-03-15" required>

      <label>Employment Status</label>
      <select name="employmentStatus">
        <option value="unemployed">Unemployed</option>
        <option value="student">Student</option>
        <option value="self-employed">Self-employed</option>
      </select>

      <!-- Training list - these match the trainings defined in user_training_server.js -->
      <label>Select a Training</label>
      <select name="trainingTitle">
        <option value="Basic Computer Skills">Basic Computer Skills (30 days)</option>
        <option value="Introduction to Excel">Introduction to Excel (20 days)</option>
        <option value="Interview Preparation and How to Write a CV">Interview Preparation and How to Write a CV (15 days)</option>
        <option value="Introduction to Email and the Internet">Introduction to Email and the Internet (15 days)</option>
        <option value="LinkedIn Profile Setup">LinkedIn Profile Setup (5 days)</option>
        <option value="Project Management Basics">Project Management Basics (30 days)</option>
        <option value="Excel Advanced">Excel Advanced (30 days)</option>
        <option value="Introduction to Digital Marketing">Introduction to Digital Marketing (30 days)</option>
      </select>

      <label>Category</label>
      <select name="category">
        <option value="basic_skills">Basic Skills</option>
        <option value="job_preparation">Job Preparation</option>
        <option value="digital_literacy">Digital Literacy</option>
      </select>

      <button type="submit">Assign Training</button>
    </form>

    <!-- If the request is successful, it will show the response from the server -->
    <% if (section === "assign" && result) { %>
      <div class="success">
        <b>✅ Enrollment ID:</b> <%= result.enrollmentId %><br>
        <b>Success:</b> <%= result.success %><br>
        <b>Message:</b> <%= result.message %>
      </div>
    <% } %>

    <!-- If there was an error, so it shows the error message -->
    <% if (section === "assign" && error) { %>
      <div class="error">❌ <%= error %></div>
    <% } %>
  </div>


  <!-- Second Service: Training Suggestion Service -->
  <!-- Using Server-side Streaming RPC, so  server sends multiple recommendations one by one to the client -->

  <div class="card">
    <h2>🎯 Get Training Recommendations</h2>

    <!-- When the form is submitted, then it sends data to /get-recommendations in app.js -->
    <form action="/get-recommendations" method="POST">

      <label>User ID</label>
      <input type="number" name="userId" placeholder="e.g. 1" required>

      <!-- Age group is used by the server to filter recommendations -->
      <label>Age Group</label>
      <select name="ageGroup">
        <option value="18-30">18-30</option>
        <option value="31-50">31-50</option>
        <option value="50+">50+</option>
      </select>

      <label>Employment Status</label>
      <select name="employmentStatus">
        <option value="Unemployed">Unemployed</option>
        <option value="Student">Student</option>
        <option value="Self-employed">Self-employed</option>
      </select>

      <label>Skill Level</label>
      <select name="skillLevel">
        <option value="Beginner">Beginner</option>
        <option value="Intermediate">Intermediate</option>
        <option value="Advanced">Advanced</option>
      </select>

      <button type="submit">Get Recommendations</button>
    </form>

    <!-- If the request is successful, then it loops through all recommendations and show each one -->
    <% if (section === "recommendations" && result) { %>
      <% result.forEach(function(r) { %>
        <div class="success">
          <b>📖 <%= r.trainingTitle %></b><br>
          Reason: <%= r.reason %><br>
          Duration: <%= r.durationHours %> hours
        </div>
      <% }) %>
    <% } %>

    <!-- If there was an error, show the error message -->
    <% if (section === "recommendations" && error) { %>
      <div class="error">❌ <%= error %></div>
    <% } %>
  </div>


  <!-- Thrid Service: Activity Notification Service-->
  <!-- Using Client-side Streaming RPC - The client sends multiple activities and receives one summary-->
  
  <div class="card">
    <h2>📊 Upload Activities</h2>

    <!-- When the form is submitted, it sends data to /upload-activity in app.js-->
    <form action="/upload-activity" method="POST">

      <label>User ID</label>
      <input type="number" name="userId" placeholder="e.g. 1" required>

      <!-- Below the client will send 3 activities (scores between 0 and 100) to the server -->
      <label>Score — Activity 1 (Module)</label>
      <input type="number" name="score1" placeholder="e.g. 80" min="0" max="100" required>

      <label>Score — Activity 2 (Quiz)</label>
      <input type="number" name="score2" placeholder="e.g. 90" min="0" max="100" required>

      <label>Score — Activity 3 (Module)</label>
      <input type="number" name="score3" placeholder="e.g. 70" min="0" max="100" required>

      <button type="submit">Upload Activities</button>
    </form>

    <!-- If it was successful, then show the summary by the server -->
    <% if (section === "activity" && result) { %>
      <div class="success">
        <b>📈 Total Activities:</b> <%= result.totalActivities %><br>
        <b>Average Score:</b> <%= result.averageScore %><br>
        <b>🏅 Badge Earned:</b> <%= result.badgeEarned %><br>
        <b>Message:</b> <%= result.message %>
      </div>
    <% } %>

    <!-- If we have an error, then it shows the error message -->
    <% if (section === "activity" && error) { %>
      <div class="error">❌ <%= error %></div>
    <% } %>
  </div>

</body>
</html>

